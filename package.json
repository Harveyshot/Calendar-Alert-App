{
  "name": "calendar-co",
  "version": "1.0.0",
  "description": "CalendarCo Desktop App by Phillip Nuckols",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --publish=never"
  },
  "build": {
    "appId": "com.phillipnuckols.calendarco",
    "productName": "CalendarCo",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  },
  "author": "Phillip Nuckols",
  "license": "MIT",
  "dependencies": {
    "@electron/remote": "^2.1.3"
  }
}
